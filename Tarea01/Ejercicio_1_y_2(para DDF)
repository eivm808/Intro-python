valor = input("Ingrese un numero de 3 digitos: ")
valor = int(valor)

def suma(num):
    if isinstance(num, int) and num >= 100 and num <= 999:
        dig_ult = num % 10
        num //= 10
        dig_med = num % 10
        num //= 10
        dig_pri = num % 10
        result = dig_ult + dig_med + dig_pri
        
        
        if (result %2 == 0):
            par = ("El resultado de la suma es Par")
            return par
        if (result %2 != 0):
            impar = ("El resultado de la suma es Impar")
            return impar
        else: 
            return -1
    return result
        

        

print(suma(valor))

